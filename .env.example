# Core network
# Socket address to listen on. Keep loopback for local-only deployments.
SECURITY_MCP_BIND_ADDR=127.0.0.1:8080
# Externally reachable origin used for MCP resource and redirect validation.
SECURITY_MCP_PUBLIC_BASE_URL=http://127.0.0.1:8080
# SQLite database used for cache entries, audit records, and OAuth state.
SECURITY_MCP_DATABASE_PATH=./security-mcp.sqlite
# Rust tracing filter, for example error, warn, info, debug, or module overrides.
SECURITY_MCP_LOG_LEVEL=info

# Deployment and request security
# Enables public deployment validation. Public mode requires HTTPS and configured auth.
SECURITY_MCP_PUBLIC_MODE=false
# Restricts analyst UI routes to loopback clients and local Host headers.
SECURITY_MCP_UI_LOCALHOST_ONLY=true
# Trust forwarded proxy headers only behind a proxy that sanitizes incoming headers.
SECURITY_MCP_TRUST_PROXY_HEADERS=false
# Permits investigation of private or loopback targets. Leave false unless required.
SECURITY_MCP_ALLOW_PRIVATE_TARGETS=false
# Requires MCP browser-origin requests to match SECURITY_MCP_PUBLIC_BASE_URL.
SECURITY_MCP_ENFORCE_MCP_ORIGIN=true

# Direct bearer authentication - configure at least one auth mode
# Shared bearer secret for MCP requests. Replace the placeholder before use.
SECURITY_MCP_BEARER_TOKEN=change-me
# Space- or comma-separated scopes granted to the configured bearer token.
SECURITY_MCP_BEARER_SCOPES=mcp:read,mcp:tools

# API key authentication
# Shared API key. Leave blank when this authentication mode is not used.
SECURITY_MCP_API_KEY=
# Space- or comma-separated scopes granted to the configured API key.
SECURITY_MCP_API_KEY_SCOPES=mcp:read,mcp:tools
# HTTP header accepted for API key authentication.
SECURITY_MCP_API_KEY_HEADER=X-API-Key
# Accepting keys in query strings can leak credentials through URLs and logs.
SECURITY_MCP_API_KEY_QUERY_ENABLED=false
# Query parameter name used only when query-string API keys are enabled.
SECURITY_MCP_API_KEY_QUERY_NAME=api_key

# OAuth-compatible connector facade
# Enables OAuth metadata, registration, authorization, and token endpoints.
SECURITY_MCP_OAUTH_ENABLED=true
# OAuth issuer origin. Set this to the public HTTPS origin in public deployments.
SECURITY_MCP_OAUTH_ISSUER=http://127.0.0.1:8080
# Secret used to protect OAuth connector onboarding. Replace the placeholder before use.
SECURITY_MCP_CONNECTOR_TOKEN=change-me
# Scopes that OAuth authorization requests may request.
SECURITY_MCP_OAUTH_ALLOWED_SCOPES=mcp:read,mcp:tools,mcp:raw,mcp:admin
# Scopes issued when an OAuth authorization request does not specify scopes.
SECURITY_MCP_OAUTH_DEFAULT_SCOPES=mcp:read,mcp:tools
# Requires OAuth requests to identify the intended protected MCP resource.
SECURITY_MCP_OAUTH_REQUIRE_RESOURCE=false
# Rejects OAuth authorization for clients that were not registered first.
SECURITY_MCP_REQUIRE_REGISTERED_OAUTH_CLIENTS=true
# Lifetime of issued OAuth access tokens, in seconds.
SECURITY_MCP_ACCESS_TOKEN_TTL_SECONDS=3600
# Lifetime of one-time OAuth authorization codes, in seconds.
SECURITY_MCP_AUTH_CODE_TTL_SECONDS=300

# Runtime controls
# Exposes the low-level expert tool in addition to high-level MCP workflows.
SECURITY_MCP_EXPERT_TOOL_ENABLED=false
# Enables SQLite-backed lookup caching.
SECURITY_MCP_CACHE_ENABLED=true
# Default outbound source-request timeout, in seconds.
SECURITY_MCP_DEFAULT_TIMEOUT_SECONDS=15
# Maximum accepted HTTP request body size, in bytes.
SECURITY_MCP_MAX_REQUEST_BODY_BYTES=1048576
# Per-minute limit for authentication-related requests per rate-limit key.
SECURITY_MCP_AUTH_RATE_LIMIT_PER_MINUTE=120
# Per-minute limit for lookup or MCP tool requests per rate-limit key.
SECURITY_MCP_LOOKUP_RATE_LIMIT_PER_MINUTE=120

# Optional source credentials - leave blank to report the source as not configured
# Increases NVD API quota for CVE enrichment requests.
NVD_API_KEY=
# Enables Shodan exposure and service intelligence lookups.
SHODAN_API_KEY=
# Enables GreyNoise IP reputation and internet-scanning context.
GREYNOISE_API_KEY=
# Enables AbuseIPDB reputation and abuse reporting context.
ABUSEIPDB_API_KEY=
# Enables VirusTotal indicator intelligence lookups.
VIRUSTOTAL_API_KEY=
# Enables URLScan search and scan-result lookups.
URLSCAN_API_KEY=
# Enables authenticated GitHub advisory search requests.
GITHUB_TOKEN=
# HTTP basic-auth credentials for CIRCL passive DNS requests.
CIRCL_PD_USER=
CIRCL_PD_PASSWORD=
